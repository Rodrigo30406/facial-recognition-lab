# Copy this file to .env and adjust values for your machine.

ENCODER_BACKEND=insightface
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_PROVIDERS=CUDAExecutionProvider,CPUExecutionProvider
INSIGHTFACE_CTX_ID=0
INSIGHTFACE_DET_SIZE=320x320
TEMPORAL_CONSISTENCY_ENABLED=true
TEMPORAL_MIN_CONSISTENT_FRAMES=3

RECOGNITION_THRESHOLD=0.5
RECOGNITION_MARGIN=0.08
RECOGNITION_TOP_K=5

DATABASE_URL=sqlite:///data/db/facial_recognition.db
SAMPLE_STORAGE_DIR=data/samples

# --- Demo defaults (scripts/run_camera_demo.py) ---
# Command-line flags still win over these values.
DEMO_CAMERA_INDEX=0
DEMO_CAMERA_ID=cam-01
DEMO_RECOGNIZE_EVERY=3
DEMO_SHOW_LANDMARKS=true

# Guided enrollment defaults
DEMO_ENROLL_PERSON_ID=alice
DEMO_GUIDED_ENROLL=true
DEMO_GUIDED_PRESET=strict

# Voice greeting defaults
DEMO_VOICE_GREET=true
DEMO_VOICE_BACKEND=melotts
DEMO_VOICE_LANG=es
DEMO_VOICE_TEMPLATE="Hola {name}"
DEMO_VOICE_REENTRY_DELAY_SECONDS=10
DEMO_VOICE_ABSENCE_SECONDS=1.5
DEMO_VOICE_MIN_FACE_RATIO=0.08
# MeloTTS settings (recommended for natural Spanish voice)
DEMO_MELO_LANGUAGE=ES
# DEMO_MELO_SPEAKER=ES
DEMO_MELO_SPEED=1.0
DEMO_MELO_DEVICE=auto
# Embedded runtime: auto-start identification when API process starts.
# Set to true on device if you want single-process boot behavior.
ELECCIA_AUTO_START_IDENTIFICATION=false
# Eleccia Core runtime modules (used by scripts/run_eleccia_core.py):
# Supported today: vision,voice
# Supported today: vision,voice,listen
ELECCIA_CORE_MODULES=vision,voice,listen
# Voice command listener module (v1 backend: stdin for local/dev)
ELECCIA_LISTEN_ENABLED=false
ELECCIA_LISTEN_BACKEND=stdin
ELECCIA_LISTEN_WAKE_WORD=eleccia
ELECCIA_LISTEN_WAKE_WORD_ALIASES=elexia,eleksia,elecia
ELECCIA_LISTEN_WAKE_WORD_FUZZY_THRESHOLD=0.80
ELECCIA_LISTEN_REQUIRE_WAKE_WORD=true
ELECCIA_LISTEN_WAKE_COMMAND_WINDOW_SECONDS=6.0
# Global audio mutex (shared by listen/voice/vision processes)
ELECCIA_AUDIO_LOCK_FILE=/tmp/eleccia_audio_io.lock
# Strict mode recommended: listen waits while voice is speaking.
ELECCIA_AUDIO_LOCK_STRICT=true
# Timeout is only used when strict mode is disabled.
ELECCIA_AUDIO_LOCK_TIMEOUT_SECONDS=10.0
ELECCIA_LISTEN_STDIN_PROMPT="eleccia> "
# Whisper STT profile (recommended for high-end GPU):
ELECCIA_LISTEN_WHISPER_MODEL=large-v3
ELECCIA_LISTEN_WHISPER_DEVICE=cuda
ELECCIA_LISTEN_WHISPER_COMPUTE_TYPE=float16
ELECCIA_LISTEN_WHISPER_LANGUAGE=es
ELECCIA_LISTEN_WHISPER_BEAM_SIZE=5
ELECCIA_LISTEN_WHISPER_VAD_FILTER=true
ELECCIA_LISTEN_WHISPER_CHUNK_SECONDS=4.0
ELECCIA_LISTEN_WHISPER_SAMPLE_RATE_HZ=16000
# ELECCIA_LISTEN_WHISPER_INPUT_DEVICE_INDEX=0
ELECCIA_LISTEN_WHISPER_MIN_RMS=0.003
# Voice-activity endpointing for whisper backend (recommended):
# Captures only while speaking, ends after silence window.
ELECCIA_LISTEN_WHISPER_ENDPOINTING_ENABLED=true
ELECCIA_LISTEN_WHISPER_FRAME_SECONDS=0.2
ELECCIA_LISTEN_WHISPER_SPEECH_START_SECONDS=0.2
ELECCIA_LISTEN_WHISPER_SILENCE_STOP_SECONDS=2.0
ELECCIA_LISTEN_WHISPER_MAX_UTTERANCE_SECONDS=8.0
ELECCIA_LISTEN_WHISPER_PRE_ROLL_SECONDS=0.3
# Timing diagnostics (logs speech start/stop, wake detection, STT latency)
ELECCIA_LISTEN_DEBUG_TIMING=false
# Lightweight adaptive noise filter before Whisper (recommended in noisy rooms)
ELECCIA_LISTEN_NOISE_FILTER_ENABLED=false
# openWakeWord + Whisper gated mode:
# ELECCIA_LISTEN_BACKEND=openwakeword_whisper
# Comma-separated custom model paths for wakeword (e.g., Eleccia)
# ELECCIA_LISTEN_OPENWAKEWORD_MODEL_PATHS=/abs/path/eleccia.onnx
ELECCIA_LISTEN_OPENWAKEWORD_INFERENCE_FRAMEWORK=onnx
ELECCIA_LISTEN_OPENWAKEWORD_THRESHOLD=0.5
ELECCIA_LISTEN_OPENWAKEWORD_CHUNK_SIZE=1280
ELECCIA_LISTEN_OPENWAKEWORD_COOLDOWN_SECONDS=1.5
# Optional args for the in-process vision module launcher:
# ELECCIA_IDENTIFICATION_ARGS="--camera-index 0 --camera-id cam-01 --recognize-every 3 --voice-greet --voice-backend melotts --show-landmarks --landmarks-max-points 50 --landmarks-every 1"
# For MeloTTS backend, install package in your environment:
# pip install "melotts @ git+https://github.com/myshell-ai/MeloTTS.git"
# Optional playback helper:
# pip install sounddevice
# Optional pyttsx3 tuning:
# DEMO_VOICE_RATE=150
# DEMO_VOICE_VOLUME=1.0
# DEMO_VOICE_ID=
